{
	"name": "gaming-tracker",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"generate-favicons": "bun scripts/generate-favicons.ts",
		"optimize-covers": "bun scripts/optimize-covers-full.ts",
		"optimize-logo": "bun scripts/optimize-logo.ts",
		"test:game-management": "vitest run tests/test-game-management.test.ts",
		"test:data-persistence": "vitest run tests/test-data-persistence.test.ts",
		"test:browser-navigation": "vitest run tests/test-browser-navigation.test.ts",
		"test:theme-switching": "vitest run tests/test-theme-switching.test.ts",
		"test:unit": "vitest run",
		"test:completed-games-caching": "vitest run tests/test-completed-games-caching.test.ts",
		"test:cover-loading": "vitest run tests/test-cover-loading.test.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:bun": "bun run test --preload ./tests/bun-setup.ts",
		"validate": "bun run lint:fix && bun run format && bun run check && bun run test",
		"clean": "bun -e \"const fs = require('fs'); ['node_modules', '.svelte-kit', 'build', '.vercel', 'bun.lock'].forEach(f => fs.rmSync(f, { recursive: true, force: true }));\" && bun install"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.5",
		"@lucide/svelte": "^0.577.0",
		"chart.js": "^4.5.1",
		"chartjs-plugin-datalabels": "^2.2.0",
		"dexie": "^4.4.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.3.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.4",
		"@vitest/coverage-v8": "^4.1.9",
		"canvas": "^3.2.3",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.7.0",
		"happy-dom": "^20.10.6",
		"jsdom": "^28.1.0",
		"postcss": "^8.5.16",
		"sharp": "^0.34.5",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	}
}
